# Anthropic — powers resume analysis, job matching, and cover letter generation
ANTHROPIC_API_KEY=sk-ant-...

# Supabase — persistent storage for resumes, saved jobs, applications, and auto-apply config
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# LinkedIn OAuth — connect your network for referral matching
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=http://localhost:3000/api/auth/linkedin/callback

# RapidAPI — Indeed and LinkedIn job search
RAPIDAPI_KEY=

# Resend — daily auto-apply report emails (https://resend.com)
RESEND_API_KEY=re_...

# Cron secret — protects /api/cron/* endpoints from unauthorized access
CRON_SECRET=
